# ========================================
# Database Configuration
# ========================================
# Votre connection string à la base de données
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://user:password@localhost:5432/ficav_db"

# ========================================
# NextAuth Configuration
# ========================================
# Générer une clé sécurisée avec: openssl rand -base64 32
NEXTAUTH_SECRET="votre_secret_aleatoire_ici"

# URL de votre site en production
# En LOCAL: http://localhost:3000
# En VERCEL: https://votre-site.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ========================================
# Firebase Configuration (Storage d'images)
# ========================================
# Créer un compte Firebase gratuit: https://firebase.google.com
# Puis créer un projet et ajouter Firebase Storage

# Votre ID de projet Firebase (trouvé dans les paramètres du projet)
FIREBASE_PROJECT_ID="votre_project_id_ici"

# Email du compte de service Firebase
# À générer dans: Firebase → Settings → Service Accounts → Generate new private key
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"

# Clé privée du compte de service Firebase (remplacer \n par du texte réel)
# ⚠️ TRÈS IMPORTANT: Remplacer les \n littéraux par des sauts de ligne réels
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nVotre_clé_privée_ici\n-----END PRIVATE KEY-----"

# Nom du bucket Firebase Storage (trouvé dans Storage settings)
# Format: votre-project.appspot.com
FIREBASE_STORAGE_BUCKET="votre_project.appspot.com"

# ========================================
# Optionnel: Google Analytics
# ========================================
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=""

# ========================================
# Optionnel: API Keys externes
# ========================================
# Ajouter ici toute autre API key nécessaire
# EXAMPLE_API_KEY="your_api_key"
